# Instance-specific configuration template
# Copy to deploy/synology/.env and fill in your values.

# ── NAS / infrastructure ─────────────────────────────────────────────────────
NAS_HOST=192.168.1.x
NAS_USER=your_ssh_user
NAS_PATH=/volume1/docker/garmin-workouts-mcp
DOMAIN=workouts.yourdomain.tld
GITHUB_REPO=https://github.com/YOUR_USER/garmin-workouts-mcp.git

# ── Bearer auth token (used by docker-compose) ───────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_TOKEN=your_64_char_hex_token_here

# ── Claude client URL ─────────────────────────────────────────────────────────
MCP_URL=https://workouts.yourdomain.tld/?token=your_64_char_hex_token_here

# ── Garmin credentials (optional — only if garth session expires) ─────────────
# GARMIN_EMAIL=your_email@garmin.com
# GARMIN_PASSWORD=your_password
